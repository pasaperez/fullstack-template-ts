{
    "name": "fullstack-template-ts",
    "version": "1.0.0",
    "description": "Production-oriented Next.js fullstack template with a single in-memory users module",
    "private": true,
    "author": {
        "name": "Angel Santiago Perez",
        "email": "pasaperez@yahoo.com.ar",
        "url": "https://github.com/pasaperez"
    },
    "license": "Apache-2.0",
    "engines": {
        "node": ">=20.0.0",
        "bun": ">=1.3.0"
    },
    "packageManager": "bun@1.3.0",
    "scripts": {
        "dev": "next dev",
        "build": "next build && tsc -p tsconfig.check.json --noEmit",
        "start": "next start",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint . --ext .ts,.tsx && depcruise --config .dependency-cruiser.cjs src",
        "lint:eslint": "eslint . --ext .ts,.tsx",
        "lint:deps": "depcruise --config .dependency-cruiser.cjs src",
        "format": "dprint check",
        "format:write": "dprint fmt"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@radix-ui/colors": "^3.0.0",
        "next": "^16.2.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.72.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@next/eslint-plugin-next": "^16.2.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.2",
        "dependency-cruiser": "^17.3.10",
        "dprint": "^0.53.1",
        "eslint": "^9.39.4",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.4.0",
        "jsdom": "^29.0.1",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    }
}
