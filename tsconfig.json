{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2022"
        ],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "noEmit": true,
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "types": [
            "vitest/globals",
            "@testing-library/jest-dom"
        ],
        "paths": {
            "@app/*": [
                "./src/app/*"
            ],
            "@composition/*": [
                "./src/composition/*"
            ],
            "@modules/*": [
                "./src/modules/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ],
            "@tests/*": [
                "./tests/*"
            ]
        },
        "allowJs": true
    },
    "include": [
        "next-env.d.ts",
        "src",
        "tests",
        "next.config.ts",
        "vitest.config.ts",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        ".next/dev/types"
    ]
}
